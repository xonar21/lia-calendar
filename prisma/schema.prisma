// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum EntryUrgency {
  LOW
  MEDIUM
  HIGH
}

enum CalendarViewMode {
  MONTH
  WEEK
  DAY
}

enum CycleMode {
  DISABLED
  ENABLED
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  name        String?
  imageUrl    String?
  timezone    String      @default("UTC")
  region      String      @default("en-US")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  categories  Category[]
  events      Event[]
  tasks       Task[]
  journals    JournalEntry[]
  notes       Note[]
  settings    UserSettings?
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  events Event[]
  tasks  Task[]
  notes  Note[]

  @@unique([userId, name])
  @@index([userId])
}

model Event {
  id          String      @id @default(cuid())
  userId      String
  categoryId  String?
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime
  urgency     EntryUrgency @default(MEDIUM)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, startsAt])
  @@index([categoryId])
}

model Task {
  id          String       @id @default(cuid())
  userId      String
  categoryId  String?
  title       String
  date        DateTime
  dueAt       DateTime?
  isCompleted Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([categoryId])
}

model JournalEntry {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  content     String
  mood        String?
  activeMs    Int?
  idleMs      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Note {
  id          String   @id @default(cuid())
  userId      String
  categoryId  String?
  title       String
  content     String
  date        DateTime
  pinnedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([categoryId])
}

model UserSettings {
  id                String           @id @default(cuid())
  userId            String           @unique
  defaultView       CalendarViewMode @default(MONTH)
  cycleMode         CycleMode        @default(DISABLED)
  cycleLengthDays   Int?
  periodLengthDays  Int?
  cycleStartDate    DateTime?
  locale            String           @default("en-US")
  timezone          String           @default("UTC")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
