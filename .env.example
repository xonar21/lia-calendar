# Database
# Use 5433 — docker-compose maps Postgres to host :5433 so it does not fight a local Postgres on :5432.
DATABASE_URL="postgresql://lia:lia@127.0.0.1:5433/lia_calendar?schema=public"

# Session signing (min 32 chars). Generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Redirect URI must be: http://localhost:3000/api/auth/google/callback in dev
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional. Leave empty to auto-detect from request host (recommended for dev).
GOOGLE_REDIRECT_URI=""

# Allow dev login form (email-only, no Google). Defaults to true outside production.
# Set to "false" to disable explicitly.
AUTH_ALLOW_DEV_LOGIN="true"
